# Tailscale Auth Key (required)
# Tailscale 认证密钥（必填）
TAILSCALE_AUTH_KEY=tskey-auth-xxx

# Tailscale Hostname (optional, defaults to derp-{DERP_IP})
# Tailscale 主机名（可选，默认 derp-{DERP_IP}）
TAILSCALE_HOSTNAME=

# Server public IP or hostname (required)
# 服务器公网 IP 或域名（必填）
DERP_IP=

# DERP Hostname (optional, fallback for DERP_IP)
# DERP 主机名（可选，DERP_IP 的备选）
DERP_HOSTNAME=

# DERP HTTPS port (default: 443)
# DERP HTTPS 端口（默认 443）
DERP_PORT=443

# STUN port (default: 3478)
# STUN 端口（默认 3478）
STUN_PORT=3478

# Tailscale P2P UDP port (default: 41641)
# Tailscale P2P 通信端口（默认 41641）
TAILSCALE_PORT=41641

# Peer Relay UDP port (default: empty = disabled, set e.g. 40000 to enable)
# Peer Relay UDP 端口（默认空=禁用，设为 40000 等值启用）
RELAY_SERVER_PORT=

# Peer Relay static endpoints (optional, comma-separated ip:port pairs)
# Peer Relay 静态端点（可选，逗号分隔的 ip:port 对）
RELAY_STATIC_ENDPOINTS=
# Example: RELAY_STATIC_ENDPOINTS=1.2.3.4:40000,5.6.7.8:40000

# Enable Exit Node (default: true)
# 启用 Exit Node（默认 true）
ENABLE_EXIT_NODE=true

# Enable client verification (default: true)
# 启用客户端验证（默认 true）
VERIFY_CLIENTS=true
